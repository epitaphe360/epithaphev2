{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": "vite",

  "buildCommand": "npm run build:client",
  "outputDirectory": "dist/public",
  "installCommand": "npm install --legacy-peer-deps",

  "redirects": [
    { "source": "/evenementiel",                      "destination": "/evenements",                              "statusCode": 301 },
    { "source": "/evenementiel/:path*",               "destination": "/evenements/:path*",                       "statusCode": 301 },
    { "source": "/communication-interne",             "destination": "/nos-poles/com-interne",                   "statusCode": 301 },
    { "source": "/communication-interne/:path*",      "destination": "/nos-poles/com-interne",                   "statusCode": 301 },
    { "source": "/communication-globale",             "destination": "/architecture-de-marque",                  "statusCode": 301 },
    { "source": "/communication-globale/:path*",      "destination": "/architecture-de-marque",                  "statusCode": 301 },
    { "source": "/digital",                           "destination": "/architecture-de-marque",                  "statusCode": 301 },
    { "source": "/digital/:path*",                    "destination": "/architecture-de-marque",                  "statusCode": 301 },
    { "source": "/contents",                          "destination": "/ressources",                              "statusCode": 301 },
    { "source": "/contents/:path*",                   "destination": "/ressources",                              "statusCode": 301 },
    { "source": "/industrie-publicitaire",            "destination": "/la-fabrique",                             "statusCode": 301 },
    { "source": "/industrie-publicitaire/:path*",     "destination": "/la-fabrique",                             "statusCode": 301 },
    { "source": "/agence-de-communication-360",       "destination": "/a-propos",                                "statusCode": 301 },
    { "source": "/communication-digitale",            "destination": "/architecture-de-marque",                  "statusCode": 301 },
    { "source": "/communication-digitale/:path*",     "destination": "/architecture-de-marque",                  "statusCode": 301 },
    { "source": "/communication-corporate",           "destination": "/architecture-de-marque",                  "statusCode": 301 },
    { "source": "/communication-corporate/:path*",    "destination": "/architecture-de-marque",                  "statusCode": 301 },
    { "source": "/communication-financiere",          "destination": "/outils/finnarrative",                     "statusCode": 301 },
    { "source": "/communication-financiere/:path*",   "destination": "/outils/finnarrative",                     "statusCode": 301 },
    { "source": "/communication-evenementielle",      "destination": "/evenements",                              "statusCode": 301 },
    { "source": "/communication-evenementielle/:path*","destination": "/evenements",                             "statusCode": 301 },
    { "source": "/communication-produits",            "destination": "/la-fabrique",                             "statusCode": 301 },
    { "source": "/communication-produits/:path*",     "destination": "/la-fabrique",                             "statusCode": 301 },
    { "source": "/nos-metiers",                       "destination": "/nos-poles",                               "statusCode": 301 },
    { "source": "/nos-metiers/:path*",                "destination": "/nos-poles",                               "statusCode": 301 },
    { "source": "/nos-solutions",                     "destination": "/outils",                                  "statusCode": 301 },
    { "source": "/nos-solutions/:path*",              "destination": "/outils",                                  "statusCode": 301 },
    { "source": "/solutions",                         "destination": "/outils",                                  "statusCode": 301 },
    { "source": "/conditions-generales-de-vente",     "destination": "/mentions-legales",                        "statusCode": 301 },
    { "source": "/politique-de-confidentialite",      "destination": "/politique-confidentialite",               "statusCode": 301 }
  ],

  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://epitaphe-backend-production.up.railway.app/api/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],

  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "X-Frame-Options",          "value": "DENY" },
        { "key": "X-XSS-Protection",         "value": "1; mode=block" },
        { "key": "Referrer-Policy",          "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}

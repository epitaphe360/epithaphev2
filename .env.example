# ========================================
# CONFIGURATION EPITAPHE 360 - VERSION SUG
# ========================================

# ========================================
# DATABASE
# ========================================
# PostgreSQL connection string (Supabase or local)
DATABASE_URL=postgresql://user:password@host:5432/database_name

# ========================================
# SERVER
# ========================================
PORT=5000
NODE_ENV=development
# development | production | test

# ========================================
# CORS & SECURITY
# ========================================
# Allowed origins (comma separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5000,https://epitaphe360.com
CORS_ORIGIN=http://localhost:5173,http://localhost:5000

# ========================================
# JWT AUTHENTICATION
# ========================================
# Generate a strong secret key: openssl rand -base64 64
JWT_SECRET=your_super_secret_jwt_key_min_32_characters_CHANGE_THIS_IN_PRODUCTION
JWT_EXPIRES_IN=7d

# ========================================
# EMAIL / SMTP (pour newsletter et notifications)
# ========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password

# Email d'expéditeur
EMAIL_FROM=contact@epitaphe360.com
EMAIL_FROM_NAME=Epitaphe 360

# ========================================
# ANALYTICS & TRACKING
# ========================================
# Google Analytics 4
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Google Tag Manager
GTM_ID=GTM-XXXXXX

# Microsoft Clarity
CLARITY_ID=xxxxxxxxxx

# Facebook Pixel
FACEBOOK_PIXEL_ID=xxxxxxxxxxxxxxxxx

# LinkedIn Insight Tag
LINKEDIN_PARTNER_ID=xxxxxxx

# ========================================
# CLOUD STORAGE (Images/Médias)
# ========================================
# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Ou AWS S3
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=eu-west-1
# AWS_S3_BUCKET=epitaphe360-media

# ========================================
# AI & CHATBOT
# ========================================
# OpenAI (pour chatbot et génération de contenu)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4

# ========================================
# INTEGRATIONS TIERCES
# ========================================
# Stripe (paiements)
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxx

# Mailchimp (newsletter)
MAILCHIMP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-us1
MAILCHIMP_AUDIENCE_ID=xxxxxxxxxx

# SendGrid (alternative email)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google reCAPTCHA v3
RECAPTCHA_SITE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RECAPTCHA_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========================================
# MONITORING & ERROR TRACKING
# ========================================
# Sentry
SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxx@sentry.io/xxxxxxx
SENTRY_ENVIRONMENT=development

# ========================================
# CDN & ASSETS
# ========================================
# Cloudflare ou autre CDN
CDN_URL=https://cdn.epitaphe360.com

# ========================================
# SOCIAL MEDIA
# ========================================
# Pour partage social et OAuth (optionnel)
FACEBOOK_APP_ID=xxxxxxxxxxxxxxxxx
TWITTER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxx
LINKEDIN_CLIENT_ID=xxxxxxxxxxxxxxxxx

# ========================================
# CALENDRIER & BOOKING
# ========================================
# Calendly (intégration booking)
CALENDLY_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========================================
# SMS (optionnel pour notifications)
# ========================================
# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+212XXXXXXXXX

# ========================================
# BACKUP & STORAGE
# ========================================
# Backup database URL (optionnel)
# BACKUP_DATABASE_URL=postgresql://user:password@backup-host:5432/backup_db

# ========================================
# RATE LIMITING
# ========================================
# Nombre max de requêtes par fenêtre (15 min)
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW_MS=900000

# Limite stricte pour auth
AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW_MS=900000

# ========================================
# LOCALE & TIMEZONE
# ========================================
DEFAULT_LOCALE=fr
DEFAULT_TIMEZONE=Africa/Casablanca

# ========================================
# FEATURE FLAGS
# ========================================
ENABLE_CHATBOT=true
ENABLE_NEWSLETTER=true
ENABLE_PROJECT_CONFIGURATOR=true
ENABLE_ANALYTICS=true
ENABLE_A_B_TESTING=false

# ========================================
# DÉVELOPPEMENT (dev uniquement)
# ========================================
# Afficher les logs SQL
DEBUG_SQL=false

# Mode debug
DEBUG=false

# Désactiver le cache en dev
DISABLE_CACHE=true

# ========================================
# PRODUCTION (production uniquement)
# ========================================
# # Forcer HTTPS
# FORCE_HTTPS=true
#
# # Trust proxy (pour Railway, Heroku, etc.)
# TRUST_PROXY=true
#
# # Compression
# ENABLE_COMPRESSION=true

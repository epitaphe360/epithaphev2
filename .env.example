# ==========================================================================
# EPITAPHE 360 — Variables d'environnement
# ==========================================================================
# LOCAL   : copier en .env et remplir les valeurs
# RAILWAY : saisir dans Dashboard → Variables (onglet Variables)
# VERCEL  : saisir dans Dashboard → Settings → Environment Variables
#           (les variables VITE_* sont injectées dans le bundle frontend)
# ==========================================================================

# ==========================================================================
# [OBLIGATOIRES RAILWAY] L'app PLANTE si ces variables sont absentes
# ==========================================================================

# URL PostgreSQL — Supabase : Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Clé secrète JWT — générer : openssl rand -base64 64
JWT_SECRET=CHANGEZ_CETTE_CLE_AVEC_AU_MOINS_64_CARACTERES_ALEATOIRES

# ==========================================================================
# [IMPORTANTES RAILWAY] Comportement incorrect sans elles
# ==========================================================================

NODE_ENV=production

# URL publique de votre app Railway (ex: https://epitaphe-prod.up.railway.app)
# Ou votre domaine custom
SITE_URL=https://epitaphe360.ma

# Origines autorisées CORS — domaines Vercel + domaine custom
# IMPORTANT: inclure votre URL Vercel (ex: https://epithaphev2.vercel.app)
CORS_ORIGIN=https://epitaphe360.ma,https://epithaphev2.vercel.app,https://epitaphe-backend-production.up.railway.app
ALLOWED_ORIGINS=https://epitaphe360.ma,https://epithaphev2.vercel.app,https://epitaphe-backend-production.up.railway.app

# Durée validité tokens JWT (défaut: 7d)
JWT_EXPIRES_IN=7d

# ==========================================================================
# [AUTOMATIQUES RAILWAY] Injectées par Railway — NE PAS définir manuellement
# ==========================================================================
# PORT                   → injecté automatiquement par Railway
# RAILWAY_PUBLIC_DOMAIN  → domaine Railway généré automatiquement
# RAILWAY_ENVIRONMENT    → "production" | "staging"

# ==========================================================================
# [VERCEL] Variables frontend — injectées dans le bundle Vite au build
# Prefixe VITE_ obligatoire pour être accessible dans le navigateur
# ==========================================================================

# URL de l'API backend Railway (utilisée si le proxy vercel.json change)
# VITE_API_URL=https://epitaphe-backend-production.up.railway.app

# ==========================================================================
# EMAIL / SMTP (pour newsletter et notifications contact)
# ==========================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password

EMAIL_FROM=contact@epitaphe360.com
EMAIL_FROM_NAME=Epitaphe 360
# Email admin — destinataire des notifications (brief, contact, newsletter)
EMAIL_ADMIN=contact@epitaphe360.ma

# ==========================================================================
# ANALYTICS & TRACKING
# ==========================================================================
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
GTM_ID=GTM-XXXXXX
CLARITY_ID=xxxxxxxxxx
FACEBOOK_PIXEL_ID=xxxxxxxxxxxxxxxxx
LINKEDIN_PARTNER_ID=xxxxxxx

# ==========================================================================
# CLOUD STORAGE (Images/Médias)
# ==========================================================================
# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Ou AWS S3
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=eu-west-1
# AWS_S3_BUCKET=epitaphe360-media

# ==========================================================================
# MONITORING & ERROR TRACKING
# ==========================================================================
SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxx@sentry.io/xxxxxxx
SENTRY_ENVIRONMENT=production

# ==========================================================================
# PUSH NOTIFICATIONS (VAPID) — Phase 2
# Générer : node -e "require('web-push').generateVAPIDKeys()"
# ==========================================================================
VAPID_PUBLIC_KEY=BJ3W90YPCtTGaaVCvZ3YKTwaeNZ-DQ1FYOzq9GNTWOnbjl2dDYQSQHhLScaojCWer4GxZCoUsr2K-Wa0RYh5DLs
VAPID_PRIVATE_KEY=MtFa9Et14fbaXezdG4eeo_aKHpcmcseh699_c1LOxwI
VAPID_EMAIL=mailto:contact@epitaphe360.com

# ==========================================================================
# WEBAUTHN / FIDO2 (Biométrie) — Phase 2
# ==========================================================================
WEBAUTHN_RP_ID=epitaphe360.com
WEBAUTHN_RP_ORIGIN=https://epitaphe360.com
# En développement local :
# WEBAUTHN_RP_ID=localhost
# WEBAUTHN_RP_ORIGIN=http://localhost:5000

# ==========================================================================
# RATE LIMITING (valeurs par défaut si absentes)
# ==========================================================================
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW_MS=900000

# ==========================================================================
# FEATURE FLAGS — activés par défaut si absentes
# ==========================================================================
ENABLE_NEWSLETTER=true
ENABLE_PROJECT_CONFIGURATOR=true
ENABLE_ANALYTICS=true

# ==========================================================================
# LOCALE & TIMEZONE
# ==========================================================================
DEFAULT_LOCALE=fr
DEFAULT_TIMEZONE=Africa/Casablanca

# ==========================================================================
# INTÉGRATIONS OPTIONNELLES
# ==========================================================================
# Stripe
# STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxx
# STRIPE_SECRET_KEY=sk_live_xxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxx

# Mailchimp
# MAILCHIMP_API_KEY=xxxxxxxxxx-us1
# MAILCHIMP_AUDIENCE_ID=xxxxxxxxxx

# reCAPTCHA v3
# RECAPTCHA_SITE_KEY=xxxxxxxxxx
# RECAPTCHA_SECRET_KEY=xxxxxxxxxx

# ─── IA — Rapports Intelligence™ (BMI 360™) ──────────────────────────────────
# Provider prioritaire : 'anthropic' (recommandé pour rapports tier-1) | 'openai' | 'auto'
# Si la clé du provider prioritaire est absente ou en erreur, fallback automatique sur l'autre.
# AI_PROVIDER=anthropic

# Anthropic Claude (PRIORITAIRE — meilleure qualité raisonnement business)
# ANTHROPIC_API_KEY=sk-ant-xxxxxx
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# OpenAI (FALLBACK)
# OPENAI_API_KEY=sk-proj-xxxxxx
# OPENAI_MODEL=gpt-4o

# Twilio SMS
# TWILIO_ACCOUNT_SID=ACxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxx
# TWILIO_PHONE_NUMBER=+212XXXXXXXXX

# ==========================================================================
# PAIEMENTS — PayPal + CMI Maroc
# ==========================================================================
# PayPal REST API v2
# PAYPAL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxx
# PAYPAL_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxx
# PAYPAL_MODE=sandbox     # 'sandbox' pour les tests, 'live' en production

# CMI (Centre Monétique Interbancaire — Maroc)
# CMI_MERCHANT_ID=xxxxxxxxxx
# CMI_STORE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# CMI_GATEWAY_URL=https://testpayment.cmi.co.ma/fim/est3Dgate
# CMI_OKURL=https://epitaphe360.ma/paiement/succes
# CMI_FAILURL=https://epitaphe360.ma/paiement/echec

# ==========================================================================
# SIMULATION PAIEMENT (Tests)
# ==========================================================================
# Active le bouton "Simuler le paiement" dans la page Intelligence Pricing
# et l'endpoint POST /api/scoring/:id/simulate-payment
# Automatiquement activé si NODE_ENV=development
# En production, décommenter pour activer explicitement :
# PAYMENT_SIMULATION_ENABLED=true
